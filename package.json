{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "node ./node_modules/prisma/build/index.js generate && node ./node_modules/@nestjs/cli/bin/nest.js build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ./node_modules/prisma/build/index.js migrate deploy",
    "prisma:migrate:dev": "node ./node_modules/prisma/build/index.js migrate dev"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "2.3.4",
    "@nestjs/common": "^11.0.10",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.10",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.10",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.3.1",
    "@supabase/supabase-js": "^2.49.1",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "prisma": "^6.3.1",
    "nodemailer": "6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/jsonwebtoken": "^9.0.8",
    "eslint": "^9.20.1",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "@typescript-eslint/parser": "^8.24.1",
    "@typescript-eslint/eslint-plugin": "^8.24.1"
  }
