# Database (Supabase Postgres)
# Use the Supabase *pooler* host (IPv4), not db.<ref>.supabase.co (often IPv6-only on Windows).
# URL-encode special chars in the password (@ -> %40).
# App runtime (transaction pooler):
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Migrations / direct session pooler:
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"
# App
NODE_ENV=development
PORT=3000
WEB_ORIGINS=http://localhost:5173
WEB_PUBLIC_URL=http://localhost:5173

# JWT
JWT_SECRET=replace-with-strong-secret-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_SCAN_SECRET=replace-with-another-strong-secret-for-qr-scan-tokens

# Rate limits — also configure @Throttle in AuthController
AUTH_THROTTLE_LIMIT=15
AUTH_THROTTLE_TTL_SECONDS=60

# Supabase — required for student photo uploads to the student-photos bucket
# Use the secret service role key here, not the publishable key.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STUDENT_PHOTOS_BUCKET=student-photos

# Optional default password for CSV student import when row has no password column
STUDENT_IMPORT_DEFAULT_PASSWORD=

# Password reset email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@example.com
